# config.env — Build-time configuration for prepare-usb.sh / prepare-head-usb.sh
# This file is tracked in git (no secrets here).

# Reserve free VG space for Rook/Ceph OSD?
#   true  → root LV is fixed at ROOT_LV_SIZE (default 45G), rest of VG is free for Ceph
#   false → root LV fills the entire VG (no space reserved)
RESERVE_CEPH_STORAGE=true

# Size of the root logical volume when RESERVE_CEPH_STORAGE=true.
# Ignored when RESERVE_CEPH_STORAGE=false.
ROOT_LV_SIZE="45G"
