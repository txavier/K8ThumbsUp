#cloud-config
#
# Autoinstall config for a Kubernetes HEAD (control-plane) node.
# This initialises the cluster, installs Calico, and configures SSH for worker auto-join.
#
autoinstall:
  version: 1
  interactive-sections: []

  locale: en_US.UTF-8
  keyboard:
    layout: us

  # The cdrom auto-source picks up /cdrom/drivers/ as an unsigned apt repo
  # (our offline OFFLINE_PACKAGES land there).  Without this conf, subiquity's
  # postinstall fails with "E: There were unauthenticated packages" when it
  # tries to download packages like iw, wpasupplicant, wireless-tools, etc.
  apt:
    conf: |
      APT::Get::AllowUnauthenticated "true";
      Acquire::AllowInsecureRepositories "true";
      Acquire::AllowDowngradeToInsecureRepositories "true";

  # WiFi via early-commands: install wpasupplicant, then netplan apply
  # Also runs crypto-scan if booted with the "SCAN FOR CRYPTO" GRUB option
  early-commands:
    - |
      IFACE=$(ls /sys/class/net/ | grep -E '^wl' | head -1)
      if [ -n "$IFACE" ]; then
        apt-get install --quiet --assume-yes --allow-unauthenticated wpasupplicant 2>/dev/null || true
        systemctl start wpa_supplicant.service 2>/dev/null || true
        rfkill unblock wifi 2>/dev/null || true
        ip link set "$IFACE" up
        printf 'network:\n  version: 2\n  wifis:\n    %s:\n      dhcp4: true\n      access-points:\n        "__WIFI_SSID__":\n          password: "__WIFI_PASSWORD__"\n' "$IFACE" > /etc/netplan/99-wifi-early.yaml
        chmod 600 /etc/netplan/99-wifi-early.yaml
        netplan apply 2>/dev/null || true
        for i in $(seq 1 30); do
          if ip addr show "$IFACE" | grep -q 'inet '; then break; fi
          sleep 2
        done
      fi
    - |
      if grep -q 'k8s.crypto-scan=1' /proc/cmdline; then
        SCAN="/cdrom/nocloud/scan.sh"
        if [ -x "$SCAN" ]; then
          echo "[autoinstall] Crypto scan requested — running..."
          bash "$SCAN"
        else
          echo "[autoinstall] ERROR: crypto-scan.sh not found at $SCAN"
          echo "Halting. Remove USB and reboot."
          while true; do sleep 3600; done
        fi
      fi
    # Hide any USB-attached block devices (other than the install medium
    # itself) from subiquity, so external USB drives plugged into the
    # target machine cannot be picked up by the storage layout or
    # accidentally wiped.  The install USB stays attached because /cdrom
    # is mounted from it.
    - |
      set +e
      INSTALL_SRC=$(findmnt -n -o SOURCE /cdrom 2>/dev/null)
      INSTALL_DEV=""
      if [ -n "$INSTALL_SRC" ]; then
        INSTALL_DEV=$(lsblk -no PKNAME "$INSTALL_SRC" 2>/dev/null | head -1)
        [ -z "$INSTALL_DEV" ] && INSTALL_DEV=$(basename "$INSTALL_SRC" | sed 's/[0-9]*$//')
      fi
      echo "[autoinstall] Install medium device: ${INSTALL_DEV:-<unknown>}"
      for dev in $(lsblk -dn -o NAME,TRAN 2>/dev/null | awk '$2=="usb"{print $1}'); do
        if [ "$dev" = "$INSTALL_DEV" ]; then
          echo "[autoinstall] Keeping install USB: /dev/$dev"
          continue
        fi
        if [ -w "/sys/block/$dev/device/delete" ]; then
          echo "[autoinstall] Detaching external USB disk: /dev/$dev"
          echo 1 > "/sys/block/$dev/device/delete"
        fi
      done
      udevadm settle
      true
    # Tear down any pre-existing LVM and wipe signatures on the largest
    # fixed (non-removable, non-USB) disk.  Without this, reinstalling onto a disk
    # that already holds an Ubuntu LVM layout makes curtin's `vgcreate
    # ubuntu-vg` fail with "/dev/ubuntu-vg: already exists in filesystem".
    - |
      set +e
      command -v vgs >/dev/null 2>&1 || apt-get install --quiet --assume-yes --allow-unauthenticated lvm2 2>/dev/null
      for vg in $(vgs --noheadings -o vg_name 2>/dev/null | awk '{print $1}'); do
        vgchange -an "$vg" 2>/dev/null
        vgremove -ff -y "$vg" 2>/dev/null
      done
      for pv in $(pvs --noheadings -o pv_name 2>/dev/null | awk '{print $1}'); do
        pvremove -ff -y "$pv" 2>/dev/null
      done
      # Skip removable AND USB-transport disks so external USB storage is never wiped.
      TARGET=$(lsblk -dn -b -o NAME,SIZE,TYPE,RM,TRAN 2>/dev/null \
        | awk '$3=="disk" && $4==0 && $5!="usb" {print $2, $1}' \
        | sort -rn | head -1 | awk '{print "/dev/"$2}')
      if [ -n "$TARGET" ] && [ -b "$TARGET" ]; then
        echo "[autoinstall] Wiping pre-existing signatures on $TARGET"
        for part in $(lsblk -ln -o NAME "$TARGET" 2>/dev/null | tail -n +2); do
          wipefs -a "/dev/$part" 2>/dev/null
        done
        wipefs -a "$TARGET" 2>/dev/null
        sgdisk --zap-all "$TARGET" 2>/dev/null || dd if=/dev/zero of="$TARGET" bs=1M count=10 2>/dev/null
        partprobe "$TARGET" 2>/dev/null
        udevadm settle
      fi
      true

  # Wipe the first disk and do a minimal install
  storage:
    layout:
      name: lvm
      sizing-policy: all

  # Create a user
  identity:
    hostname: k8s-head
    username: kube
    password: "__PASSWORD_HASH__"

  # Install SSH during OS installation
  ssh:
    install-server: true
    allow-pw: true

  # Minimal package set — late-commands handle the rest.
  #
  # Everything here must be resolvable by subiquity's `packages:` phase,
  # which only sees the live ISO's cdrom: pool (main/restricted) plus
  # whatever is in OFFLINE_PACKAGES via /cdrom/drivers/.  Anything outside
  # that — notably `linux-headers-generic` (metapackage; the offline repo
  # would pull a kernel-ABI mismatch) and `dkms` (universe) — must be
  # installed in late-commands instead, where the online mirror or the
  # offline repo are available.  `dkms` + headers get pulled in as deps
  # of the realtek-rtl88xxau-dkms install below.
  packages:
    - curl
    - ca-certificates
    - gpg
    - apt-transport-https
    - linux-firmware
    - wpasupplicant
    - iw
    - wireless-tools

  # Disable swap partition
  swap:
    size: 0

  # Run head-node setup steps after install, before first reboot
  #
  # IMPORTANT: File-write operations come FIRST (before any chroot/apt commands)
  # because subiquity stops processing late-commands if any command fails.
  #
  late-commands:
    # Install Realtek USB WiFi drivers (RTL8812AU/8821AU/8814AU) from multiverse
    # These are common USB adapters not supported by the mainline kernel
    - curtin in-target --target=/target -- add-apt-repository multiverse -y
    - curtin in-target --target=/target -- apt-get install -y realtek-rtl88xxau-dkms
    # RTL8852CU USB WiFi 6 driver, built from source by prepare-head-usb.sh
    - curtin in-target --target=/target -- apt-get install -y --allow-unauthenticated rtl8852cu-dkms || true

    # Always write the WiFi netplan with a glob match on wl*.
    # See autoinstall/user-data for the full rationale: USB WiFi adapters
    # driven by DKMS modules we install into /target are not probed by the
    # live installer kernel, so detecting wl* at late-command time misses
    # them.  A `match: name: "wl*"` binds whatever interface udev creates
    # at first boot.
    - |
      cat > /target/etc/netplan/90-wifi.yaml <<WIFIEOF
      network:
        version: 2
        wifis:
          all-wl:
            match:
              name: "wl*"
            dhcp4: true
            optional: true
            access-points:
              "__WIFI_SSID__":
                password: "__WIFI_PASSWORD__"
      WIFIEOF
      chmod 600 /target/etc/netplan/90-wifi.yaml

    # Always write a fallback ethernet netplan that DHCPs on any wired NIC.
    # Without this, wired-only boxes (e.g. Optiplex 3090 with no WiFi card)
    # come up with no network at all: subiquity only writes a netplan entry
    # for interfaces that were actually used during install, so if WiFi was
    # the install path the wired NIC is omitted; and we disable cloud-init
    # below, so it cannot recover at first boot.
    - |
      cat > /target/etc/netplan/80-ethernet-fallback.yaml <<ETHEOF
      network:
        version: 2
        ethernets:
          all-en:
            match:
              name: "en*"
            dhcp4: true
            optional: true
          all-eth:
            match:
              name: "eth*"
            dhcp4: true
            optional: true
      ETHEOF
      chmod 600 /target/etc/netplan/80-ethernet-fallback.yaml

    # Set hostname
    - echo "k8s-head" > /target/etc/hostname
    - sed -i "s/k8s-head/k8s-head/g" /target/etc/hosts

    # Disable swap in fstab
    - sed -i '/\sswap\s/s/^/#/' /target/etc/fstab

    # Keep running with lid closed
    - |
      mkdir -p /target/etc/systemd/logind.conf.d
      cat > /target/etc/systemd/logind.conf.d/lid.conf <<EOF
      [Login]
      HandleLidSwitch=ignore
      HandleLidSwitchExternalPower=ignore
      HandleLidSwitchDocked=ignore
      EOF

    # Kernel modules for Kubernetes
    - |
      cat > /target/etc/modules-load.d/k8s.conf <<EOF
      overlay
      br_netfilter
      EOF

    # Sysctl params for Kubernetes networking
    - |
      cat > /target/etc/sysctl.d/k8s.conf <<EOF
      net.bridge.bridge-nf-call-iptables  = 1
      net.bridge.bridge-nf-call-ip6tables = 1
      net.ipv4.ip_forward                 = 1
      EOF

    # Disable cloud-init on the installed system
    - mkdir -p /target/etc/cloud && touch /target/etc/cloud/cloud-init.disabled

    # Install SSH public key for worker auto-join (restricted to the
    # print-join wrapper script installed below)
    - |
      mkdir -p /target/home/kube/.ssh
      cat > /target/home/kube/.ssh/authorized_keys <<'AUTHEOF'
      __NODE_JOIN_AUTHORIZED_KEY__
      AUTHEOF
    - sed -i 's/^      //' /target/home/kube/.ssh/authorized_keys
    - chmod 700 /target/home/kube/.ssh
    - chmod 600 /target/home/kube/.ssh/authorized_keys
    - chown -R 1000:1000 /target/home/kube/.ssh

    # Install the print-join-command wrapper.  When a worker SSHes in, the
    # forced-command in authorized_keys runs this script.  It deletes any
    # stale Node object whose name matches the joining worker's hostname
    # (passed via SSH_ORIGINAL_COMMAND), then prints a fresh join command.
    # This lets workers be reimaged without manual `kubectl delete node`.
    - |
      cat > /target/usr/local/bin/k8s-print-join-command.sh <<'PJCEOF'
      #!/usr/bin/env bash
      set -euo pipefail
      KUBECONFIG="${KUBECONFIG:-/home/kube/.kube/config}"
      LOG_TAG="k8s-print-join-command"
      requested="${SSH_ORIGINAL_COMMAND:-}"
      if [[ "$requested" =~ ^k8s-node-[a-f0-9]{6}$ ]]; then
        if kubectl --kubeconfig="$KUBECONFIG" get node "$requested" >/dev/null 2>&1; then
          echo "[$LOG_TAG] deleting stale node object: $requested" >&2
          kubectl --kubeconfig="$KUBECONFIG" delete node "$requested" \
            --ignore-not-found --wait=false >&2 || \
            echo "[$LOG_TAG] WARN: kubectl delete node $requested failed" >&2
        fi
      elif [[ -n "$requested" ]]; then
        echo "[$LOG_TAG] WARN: ignoring unexpected SSH_ORIGINAL_COMMAND: $requested" >&2
      fi
      exec kubeadm token create --print-join-command
      PJCEOF
    - sed -i 's/^      //' /target/usr/local/bin/k8s-print-join-command.sh
    - chmod 755 /target/usr/local/bin/k8s-print-join-command.sh
    - chown root:root /target/usr/local/bin/k8s-print-join-command.sh

    # Install kubeadm-init script (runs on first boot to initialise the cluster)
    - |
      cat > /target/usr/local/bin/k8s-head-init.sh <<'SCRIPTEOF'
      #!/usr/bin/env bash
      set -euo pipefail
      POD_CIDR="__POD_CIDR__"
      LOG="/var/log/k8s-head-init.log"
      STAMP="/etc/kubernetes/.head-init-done"
      exec > >(tee -a "$LOG") 2>&1
      echo "[$(date)] head-init: starting"
      if [[ -f "$STAMP" ]]; then
        echo "[$(date)] head-init: already initialised, skipping"
        exit 0
      fi
      # Wait for network
      echo "[$(date)] head-init: waiting for network..."
      for i in $(seq 1 30); do
        if ip route | grep -q default; then
          echo "[$(date)] head-init: network up"
          break
        fi
        sleep 5
      done
      # Load kernel modules
      modprobe overlay 2>/dev/null || true
      modprobe br_netfilter 2>/dev/null || true
      sysctl --system >/dev/null 2>&1 || true
      # Ensure containerd is running
      systemctl start containerd 2>/dev/null || true
      # Initialise the cluster
      echo "[$(date)] head-init: running kubeadm init..."
      kubeadm init --pod-network-cidr="$POD_CIDR" 2>&1
      # Set up kubectl for kube user
      KUBE_HOME="/home/kube"
      mkdir -p "$KUBE_HOME/.kube"
      cp /etc/kubernetes/admin.conf "$KUBE_HOME/.kube/config"
      chown -R 1000:1000 "$KUBE_HOME/.kube"
      # Also set up for root
      mkdir -p /root/.kube
      cp /etc/kubernetes/admin.conf /root/.kube/config
      # Install Calico CNI
      echo "[$(date)] head-init: installing Calico..."
      export KUBECONFIG=/etc/kubernetes/admin.conf
      kubectl create -f https://raw.githubusercontent.com/projectcalico/calico/v3.29.2/manifests/tigera-operator.yaml 2>&1 || true
      # Wait briefly for the operator CRDs to register
      sleep 10
      # Apply Calico Installation CR
      cat <<CALICOEOF | kubectl apply -f - 2>&1
      apiVersion: operator.tigera.io/v1
      kind: Installation
      metadata:
        name: default
      spec:
        calicoNetwork:
          ipPools:
          - name: default-ipv4-ippool
            blockSize: 26
            cidr: ${POD_CIDR}
            encapsulation: VXLANCrossSubnet
            natOutgoing: Enabled
            nodeSelector: all()
      ---
      apiVersion: operator.tigera.io/v1
      kind: APIServer
      metadata:
        name: default
      spec: {}
      CALICOEOF
      # Mark as done
      mkdir -p /etc/kubernetes
      touch "$STAMP"
      echo "[$(date)] head-init: cluster initialised successfully"
      echo "[$(date)] head-init: run 'kubectl get nodes' to verify"
      SCRIPTEOF
    - chmod 755 /target/usr/local/bin/k8s-head-init.sh

    # Create systemd service for first-boot head-node init
    - |
      cat > /target/etc/systemd/system/k8s-head-init.service <<'SVCEOF'
      [Unit]
      Description=Initialise Kubernetes control-plane (head node)
      After=network-online.target containerd.service
      Wants=network-online.target
      ConditionPathExists=!/etc/kubernetes/.head-init-done

      [Service]
      Type=oneshot
      ExecStart=/usr/local/bin/k8s-head-init.sh
      RemainAfterExit=true
      TimeoutStartSec=600

      [Install]
      WantedBy=multi-user.target
      SVCEOF

    # Install ~/save-logs.sh for kube user
    - |
      cat > /target/home/kube/save-logs.sh <<'SLEOF'
      #!/usr/bin/env bash
      set -euo pipefail
      if [ "$(id -u)" -ne 0 ]; then echo "Run with sudo"; exit 1; fi
      USB_PART=$(blkid -t LABEL="CIDATA" -o device 2>/dev/null | head -1)
      if [ -z "$USB_PART" ]; then
        echo "ERROR: No USB partition with label CIDATA found."
        echo "Make sure the install USB drive is plugged in."
        exit 1
      fi
      MNT="/tmp/usb-logs-$$"
      mkdir -p "$MNT"
      if ! mount "$USB_PART" "$MNT" 2>/dev/null; then
        echo "ERROR: Failed to mount $USB_PART"
        exit 1
      fi
      trap 'sync; umount "$MNT" 2>/dev/null; rmdir "$MNT" 2>/dev/null' EXIT
      LOGDIR="$MNT/boot-logs/$(hostname)/$(date +%Y%m%d-%H%M%S)"
      mkdir -p "$LOGDIR"
      echo "Saving logs to USB..."
      journalctl --boot --no-pager > "$LOGDIR/journalctl-boot.log" 2>&1 || true
      dmesg > "$LOGDIR/dmesg.log" 2>&1 || true
      systemctl --failed --no-pager > "$LOGDIR/failed-services.log" 2>&1 || true
      systemctl status k8s-head-init.service --no-pager > "$LOGDIR/k8s-head-init-status.log" 2>&1 || true
      journalctl -u k8s-head-init.service --no-pager > "$LOGDIR/k8s-head-init-journal.log" 2>&1 || true
      ip addr > "$LOGDIR/ip-addr.log" 2>&1 || true
      ip route > "$LOGDIR/ip-route.log" 2>&1 || true
      cat /etc/resolv.conf > "$LOGDIR/resolv.conf.log" 2>&1 || true
      kubectl get nodes > "$LOGDIR/kubectl-nodes.log" 2>&1 || true
      kubectl get pods -A > "$LOGDIR/kubectl-pods-all.log" 2>&1 || true
      echo "Done. Logs saved. USB will be unmounted automatically."
      ls -la "$LOGDIR"
      SLEOF
    - sed -i 's/^      //' /target/home/kube/save-logs.sh
    - chmod 755 /target/home/kube/save-logs.sh
    - chown 1000:1000 /target/home/kube/save-logs.sh

    # Install boot-log-to-USB script
    - |
      cat > /target/usr/local/bin/save-boot-logs-usb.sh <<'BLOGEOF'
      #!/usr/bin/env bash
      set -euo pipefail
      USB_PART=$(blkid -t LABEL="CIDATA" -o device 2>/dev/null | head -1)
      if [ -z "$USB_PART" ]; then
        echo "No CIDATA USB found, skipping boot log save"
        exit 0
      fi
      MOUNT_DIR="/tmp/usb-bootlogs"
      mkdir -p "$MOUNT_DIR"
      mount "$USB_PART" "$MOUNT_DIR" || exit 1
      LOGDIR="$MOUNT_DIR/boot-logs/$(hostname)/$(date +%Y%m%d-%H%M%S)"
      mkdir -p "$LOGDIR"
      journalctl --boot --no-pager > "$LOGDIR/journalctl-boot.log" 2>&1 || true
      dmesg > "$LOGDIR/dmesg.log" 2>&1 || true
      systemctl --failed --no-pager > "$LOGDIR/failed-services.log" 2>&1 || true
      sync
      umount "$MOUNT_DIR"
      echo "Boot logs saved to $LOGDIR"
      BLOGEOF
    - sed -i 's/^      //' /target/usr/local/bin/save-boot-logs-usb.sh
    - chmod 755 /target/usr/local/bin/save-boot-logs-usb.sh

    # Systemd service to run boot-log save after boot completes
    - |
      cat > /target/etc/systemd/system/save-boot-logs-usb.service <<'SVCEOF'
      [Unit]
      Description=Save boot logs to USB if plugged in
      After=multi-user.target

      [Service]
      Type=oneshot
      ExecStartPre=/bin/sleep 30
      ExecStart=/usr/local/bin/save-boot-logs-usb.sh
      RemainAfterExit=true

      [Install]
      WantedBy=multi-user.target
      SVCEOF

    # Enable custom services via symlinks
    - |
      mkdir -p /target/etc/systemd/system/multi-user.target.wants
      ln -sf /etc/systemd/system/k8s-head-init.service /target/etc/systemd/system/multi-user.target.wants/k8s-head-init.service
      ln -sf /etc/systemd/system/save-boot-logs-usb.service /target/etc/systemd/system/multi-user.target.wants/save-boot-logs-usb.service

    # --- Network-dependent section below ---
    # Re-establish WiFi then verify DNS
    - |
      IFACE=$(ls /sys/class/net/ | grep -E '^wl' | head -1)
      if [ -n "$IFACE" ]; then
        printf 'network:\n  version: 2\n  wifis:\n    %s:\n      dhcp4: true\n      access-points:\n        "__WIFI_SSID__":\n          password: "__WIFI_PASSWORD__"\n' "$IFACE" > /etc/netplan/99-wifi-early.yaml
        chmod 600 /etc/netplan/99-wifi-early.yaml
        netplan apply 2>/dev/null || true
        echo "Waiting for WiFi IP..." >&2
        for i in $(seq 1 30); do
          if ip addr show "$IFACE" | grep -q 'inet '; then echo "WiFi up" >&2; break; fi
          sleep 2
        done
        ip addr show "$IFACE" >&2
      fi
      echo "Waiting for DNS..." >&2
      for i in $(seq 1 30); do
        if getent hosts archive.ubuntu.com >/dev/null 2>&1; then
          echo "DNS working" >&2
          break
        fi
        sleep 2
      done
      if ! getent hosts archive.ubuntu.com >/dev/null 2>&1; then
        echo "WARNING: DNS not working after 60s, apt commands may fail" >&2
      fi

    # Set up bind mounts so chroot has working DNS + devices
    - |
      mount --bind /dev /target/dev
      mount --bind /proc /target/proc
      mount --bind /run /target/run
      mount --bind /sys /target/sys

    # Install containerd + Kubernetes packages
    - |
      set +e
      echo "=== Installing containerd ===" >&2
      for attempt in 1 2 3; do
        chroot /target apt-get update -qq 2>&1 && break
        echo "apt-get update attempt $attempt failed, retrying in 10s..." >&2
        sleep 10
      done
      mkdir -p /target/etc/apt/preferences.d
      printf 'Package: containerd\nPin: version 1.7.28*\nPin-Priority: 1001\n' > /target/etc/apt/preferences.d/containerd-pin
      chroot /target apt-get install -y -qq containerd 2>&1
      chroot /target mkdir -p /etc/containerd
      chroot /target bash -c "containerd config default > /etc/containerd/config.toml" 2>&1
      sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /target/etc/containerd/config.toml 2>/dev/null
      chroot /target systemctl enable containerd 2>&1

      echo "=== Adding Kubernetes apt repo ===" >&2
      chroot /target mkdir -p /etc/apt/keyrings
      # Fetch with -4 (avoid IPv6 hangs on AAAA-only DNS), retry, and refuse to
      # install a 0-byte keyring \u2014 that would poison apt-get update with NO_PUBKEY.
      KEYRING_OK=0
      for attempt in 1 2 3; do
        rm -f /target/tmp/k8s-release.key /target/tmp/k8s-release.gpg
        if chroot /target bash -c 'curl -4 -fsSL --max-time 30 -o /tmp/k8s-release.key https://pkgs.k8s.io/core:/stable:/v1.35/deb/Release.key && [ -s /tmp/k8s-release.key ] && gpg --dearmor -o /tmp/k8s-release.gpg /tmp/k8s-release.key && [ -s /tmp/k8s-release.gpg ]' 2>&1; then
          mv /target/tmp/k8s-release.gpg /target/etc/apt/keyrings/kubernetes-apt-keyring.gpg
          chmod 0644 /target/etc/apt/keyrings/kubernetes-apt-keyring.gpg
          rm -f /target/tmp/k8s-release.key
          KEYRING_OK=1
          break
        fi
        echo "keyring fetch attempt $attempt failed, retrying in 10s..." >&2
        sleep 10
      done
      if [ "$KEYRING_OK" = 1 ]; then
        echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.35/deb/ /" \
          > /target/etc/apt/sources.list.d/kubernetes.list
      else
        echo "=== ERROR: kubernetes keyring fetch failed (head node has no auto-join fallback) ===" >&2
        rm -f /target/etc/apt/keyrings/kubernetes-apt-keyring.gpg /target/etc/apt/sources.list.d/kubernetes.list
      fi

      echo "=== Installing kubeadm, kubelet, kubectl ===" >&2
      for attempt in 1 2 3; do
        chroot /target apt-get update -qq 2>&1 && break
        echo "apt-get update attempt $attempt failed, retrying in 10s..." >&2
        sleep 10
      done
      chroot /target apt-get install -y -qq kubelet kubeadm kubectl 2>&1
      chroot /target apt-mark hold kubelet kubeadm kubectl 2>&1
      chroot /target systemctl enable kubelet 2>&1

      # Report result
      if chroot /target which kubeadm >/dev/null 2>&1; then
        echo "=== Kubernetes packages installed successfully ===" >&2
      else
        echo "=== WARNING: Kubernetes packages NOT installed (DNS/network issue during install) ===" >&2
        echo "=== Run node-setup.sh manually after boot to complete setup ===" >&2
      fi
      true

    # Clean up bind mounts
    - |
      umount /target/sys 2>/dev/null || true
      umount /target/run 2>/dev/null || true
      umount /target/proc 2>/dev/null || true
      umount /target/dev 2>/dev/null || true

    # ---- Install UEFI removable-media fallback (\EFI\BOOT\BOOTX64.EFI) ----
    # See autoinstall/user-data for rationale.
    - |
      set +e
      LOG=/var/log/installer/efi-fallback.log
      mkdir -p /var/log/installer
      exec >>"$LOG" 2>&1
      echo "==== EFI fallback install at $(date -Iseconds) ===="
      ESP_MNT=$(findmnt -no TARGET /target/boot/efi)
      if [ -z "$ESP_MNT" ] || [ ! -f "$ESP_MNT/EFI/ubuntu/shimx64.efi" ]; then
        echo "Skipping: ESP not mounted or shim not present"
        exit 0
      fi
      mkdir -p "$ESP_MNT/EFI/BOOT"
      cp -f "$ESP_MNT/EFI/ubuntu/shimx64.efi"   "$ESP_MNT/EFI/BOOT/BOOTX64.EFI"
      [ -f "$ESP_MNT/EFI/ubuntu/grubx64.efi" ] && \
        cp -f "$ESP_MNT/EFI/ubuntu/grubx64.efi" "$ESP_MNT/EFI/BOOT/grubx64.efi"
      [ -f "$ESP_MNT/EFI/ubuntu/mmx64.efi" ] && \
        cp -f "$ESP_MNT/EFI/ubuntu/mmx64.efi"   "$ESP_MNT/EFI/BOOT/mmx64.efi"
      sync
      ls -la "$ESP_MNT/EFI/BOOT/"
      true

    # Copy install logs to USB drive for debugging
    - |
      USB_PART=$(blkid -t LABEL="CIDATA" -o device 2>/dev/null | head -1)
      if [ -n "$USB_PART" ]; then
        mkdir -p /tmp/usblogs
        mount "$USB_PART" /tmp/usblogs 2>/dev/null || true
        if mountpoint -q /tmp/usblogs; then
          LOGDIR="/tmp/usblogs/install-logs/$(date +%Y%m%d-%H%M%S)"
          mkdir -p "$LOGDIR"
          cp /var/log/installer/*.log "$LOGDIR/" 2>/dev/null || true
          cp /autoinstall.yaml "$LOGDIR/" 2>/dev/null || true
          sync
          umount /tmp/usblogs
        fi
      fi
