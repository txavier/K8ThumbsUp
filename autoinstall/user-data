#cloud-config
#
# Set a custom hostname below, or leave empty for auto-generated (k8s-node-<mac>)
# NODE_HOSTNAME: my-node-name
#
autoinstall:
  version: 1
  interactive-sections: []

  locale: en_US.UTF-8
  keyboard:
    layout: us

  # WiFi via early-commands: install wpasupplicant, then netplan apply
  early-commands:
    - |
      IFACE=$(ls /sys/class/net/ | grep -E '^wl' | head -1)
      if [ -n "$IFACE" ]; then
        apt-get install --quiet --assume-yes wpasupplicant 2>/dev/null || true
        systemctl start wpa_supplicant.service 2>/dev/null || true
        rfkill unblock wifi 2>/dev/null || true
        ip link set "$IFACE" up
        printf 'network:\n  version: 2\n  wifis:\n    %s:\n      dhcp4: true\n      access-points:\n        "__WIFI_SSID__":\n          password: "__WIFI_PASSWORD__"\n' "$IFACE" > /etc/netplan/99-wifi-early.yaml
        chmod 600 /etc/netplan/99-wifi-early.yaml
        netplan apply 2>/dev/null || true
        for i in $(seq 1 30); do
          if ip addr show "$IFACE" | grep -q 'inet '; then break; fi
          sleep 2
        done
      fi

  # Wipe the first disk — 45G root LV, remaining VG space for Rook/Ceph OSD
  storage:
    swap:
      size: 0
    config:
      - {id: disk0, type: disk, ptable: gpt, wipe: superblock-recursive,
         grub_device: false, match: {size: largest}}
      - {id: efi-part, type: partition, device: disk0, size: 1G,
         flag: boot, grub_device: true}
      - {id: boot-part, type: partition, device: disk0, size: 2G}
      - {id: lvm-part, type: partition, device: disk0, size: -1}
      - {id: efi-fmt, type: format, volume: efi-part, fstype: fat32}
      - {id: boot-fmt, type: format, volume: boot-part, fstype: ext4}
      - {id: vg0, type: lvm_volgroup, name: ubuntu-vg, devices: [lvm-part]}
      - {id: lv-root, type: lvm_partition, volgroup: vg0,
         name: ubuntu-lv, size: 45G}
      - {id: root-fmt, type: format, volume: lv-root, fstype: ext4}
      - {id: mnt-root, type: mount, device: root-fmt, path: /}
      - {id: mnt-boot, type: mount, device: boot-fmt, path: /boot}
      - {id: mnt-efi, type: mount, device: efi-fmt, path: /boot/efi}

  # Create a user — change password before use!
  # Generate a hash: mkpasswd --method=SHA-512 yourpassword
  # Set PASSWORD_HASH env var or put it in secrets.env before running prepare-usb.sh
  identity:
    hostname: k8s-node
    username: kube
    password: "__PASSWORD_HASH__"

  # Install SSH during OS installation
  ssh:
    install-server: true
    allow-pw: true

  # Minimal package set — node-setup.sh handles the rest
  packages:
    - curl
    - ca-certificates
    - gpg
    - apt-transport-https

  # Disable swap partition (Ubuntu Server sometimes creates one)
  swap:
    size: 0

  # Run node-setup steps after install, before first reboot
  #
  # IMPORTANT: File-write operations come FIRST (before any chroot/apt commands)
  # because subiquity stops processing late-commands if any command fails.
  # This ensures scripts, services, and configs are always written to disk
  # even if apt-get fails due to DNS issues during install.
  #
  late-commands:
    # Persist WiFi config in the installed system (detect actual wireless interface name)
    - |
      WIFI_IFACE=$(ls /sys/class/net/ | grep -E '^wl' | head -1)
      if [ -n "$WIFI_IFACE" ]; then
        cat > /target/etc/netplan/90-wifi.yaml <<WIFIEOF
      network:
        version: 2
        wifis:
          ${WIFI_IFACE}:
            dhcp4: true
            access-points:
              "__WIFI_SSID__":
                password: "__WIFI_PASSWORD__"
      WIFIEOF
        chmod 600 /target/etc/netplan/90-wifi.yaml
      fi

    # Set hostname: uses NODE_HOSTNAME from top of file if set, otherwise auto-generates from MAC
    - |
      CUSTOM=$(grep '^NODE_HOSTNAME:' /autoinstall.yaml 2>/dev/null | awk '{print $2}' || true)
      if [ -n "$CUSTOM" ]; then
        NODENAME="$CUSTOM"
      else
        MAC_SUFFIX=$(ip link show | awk '/ether/{print $2; exit}' | tr -d ':' | tail -c 7)
        NODENAME="k8s-node-${MAC_SUFFIX}"
      fi
      echo "$NODENAME" > /target/etc/hostname
      sed -i "s/k8s-node/$NODENAME/g" /target/etc/hosts

    # Disable swap in fstab
    - sed -i '/\sswap\s/s/^/#/' /target/etc/fstab

    # Keep running with lid closed (servers don't need to sleep)
    - |
      mkdir -p /target/etc/systemd/logind.conf.d
      cat > /target/etc/systemd/logind.conf.d/lid.conf <<EOF
      [Login]
      HandleLidSwitch=ignore
      HandleLidSwitchExternalPower=ignore
      HandleLidSwitchDocked=ignore
      EOF

    # Kernel modules for Kubernetes
    - |
      cat > /target/etc/modules-load.d/k8s.conf <<EOF
      overlay
      br_netfilter
      EOF

    # Sysctl params for Kubernetes networking
    - |
      cat > /target/etc/sysctl.d/k8s.conf <<EOF
      net.bridge.bridge-nf-call-iptables  = 1
      net.bridge.bridge-nf-call-ip6tables = 1
      net.ipv4.ip_forward                 = 1
      EOF

    # Disable cloud-init on the installed system (only needed during autoinstall)
    - mkdir -p /target/etc/cloud && touch /target/etc/cloud/cloud-init.disabled

    # Install SSH private key for auto-join (restricted to token command only on master)
    - |
      mkdir -p /target/etc/kubernetes
      cat > /target/etc/kubernetes/node-join-key <<'KEYEOF'
      __NODE_JOIN_KEY_PLACEHOLDER__
      KEYEOF
    - sed -i 's/^      //' /target/etc/kubernetes/node-join-key
    - chmod 600 /target/etc/kubernetes/node-join-key

    # Install auto-join script
    - |
      cat > /target/usr/local/bin/k8s-auto-join.sh <<'SCRIPTEOF'
      #!/usr/bin/env bash
      set -euo pipefail
      MASTER_IP="__MASTER_IP__"
      MASTER_USER="__MASTER_USER__"
      SSH_KEY="/etc/kubernetes/node-join-key"
      LOG="/var/log/k8s-auto-join.log"
      STAMP="/etc/kubernetes/.joined"
      exec > >(tee -a "$LOG") 2>&1
      echo "[$(date)] auto-join: starting"
      if [[ -f "$STAMP" ]]; then
        echo "[$(date)] auto-join: already joined, skipping"
        exit 0
      fi
      echo "[$(date)] auto-join: waiting for network..."
      for i in $(seq 1 30); do
        if ping -c1 -W2 "$MASTER_IP" >/dev/null 2>&1; then
          echo "[$(date)] auto-join: master reachable"
          break
        fi
        sleep 5
      done
      if ! ping -c1 -W2 "$MASTER_IP" >/dev/null 2>&1; then
        echo "[$(date)] auto-join: ERROR — cannot reach master at $MASTER_IP"
        exit 1
      fi
      echo "[$(date)] auto-join: requesting join command from master..."
      JOIN_CMD=$(ssh -i "$SSH_KEY" -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10 "${MASTER_USER}@${MASTER_IP}" 2>/dev/null)
      if [[ -z "$JOIN_CMD" || ! "$JOIN_CMD" =~ "kubeadm join" ]]; then
        echo "[$(date)] auto-join: ERROR — did not receive a valid join command"
        exit 1
      fi
      echo "[$(date)] auto-join: joining cluster..."
      $JOIN_CMD
      mkdir -p /etc/kubernetes
      touch "$STAMP"
      echo "[$(date)] auto-join: successfully joined the cluster"
      SCRIPTEOF
    - chmod 755 /target/usr/local/bin/k8s-auto-join.sh

    # Create systemd service for first-boot auto-join
    - |
      cat > /target/etc/systemd/system/k8s-auto-join.service <<'SVCEOF'
      [Unit]
      Description=Auto-join Kubernetes cluster
      After=network-online.target
      Wants=network-online.target
      ConditionPathExists=!/etc/kubernetes/.joined

      [Service]
      Type=oneshot
      ExecStart=/usr/local/bin/k8s-auto-join.sh
      RemainAfterExit=true

      [Install]
      WantedBy=multi-user.target
      SVCEOF

    # Install ~/save-logs.sh for kube user (mounts USB, saves logs, unmounts)
    - |
      cat > /target/home/kube/save-logs.sh <<'SLEOF'
      #!/usr/bin/env bash
      set -euo pipefail
      if [ "$(id -u)" -ne 0 ]; then echo "Run with sudo"; exit 1; fi
      USB_PART=$(blkid -t LABEL="CIDATA" -o device 2>/dev/null | head -1)
      if [ -z "$USB_PART" ]; then
        echo "ERROR: No USB partition with label CIDATA found."
        echo "Make sure the install USB drive is plugged in."
        exit 1
      fi
      MNT="/tmp/usb-logs-$$"
      mkdir -p "$MNT"
      if ! mount "$USB_PART" "$MNT" 2>/dev/null; then
        echo "ERROR: Failed to mount $USB_PART"
        exit 1
      fi
      trap 'sync; umount "$MNT" 2>/dev/null; rmdir "$MNT" 2>/dev/null' EXIT
      LOGDIR="$MNT/boot-logs/$(hostname)/$(date +%Y%m%d-%H%M%S)"
      mkdir -p "$LOGDIR"
      echo "Saving logs to USB..."
      journalctl --boot --no-pager > "$LOGDIR/journalctl-boot.log" 2>&1 || true
      dmesg > "$LOGDIR/dmesg.log" 2>&1 || true
      systemctl --failed --no-pager > "$LOGDIR/failed-services.log" 2>&1 || true
      systemctl status save-boot-logs-usb.service --no-pager > "$LOGDIR/save-boot-logs-status.log" 2>&1 || true
      journalctl -u save-boot-logs-usb.service --no-pager > "$LOGDIR/save-boot-logs-journal.log" 2>&1 || true
      systemctl status k8s-auto-join.service --no-pager > "$LOGDIR/k8s-auto-join-status.log" 2>&1 || true
      journalctl -u k8s-auto-join.service --no-pager > "$LOGDIR/k8s-auto-join-journal.log" 2>&1 || true
      ip addr > "$LOGDIR/ip-addr.log" 2>&1 || true
      ip route > "$LOGDIR/ip-route.log" 2>&1 || true
      cat /etc/resolv.conf > "$LOGDIR/resolv.conf.log" 2>&1 || true
      kubectl get nodes --kubeconfig /etc/kubernetes/kubelet.conf > "$LOGDIR/kubectl-nodes.log" 2>&1 || true
      echo "Done. Logs saved. USB will be unmounted automatically."
      ls -la "$LOGDIR"
      SLEOF
    - sed -i 's/^      //' /target/home/kube/save-logs.sh
    - chmod 755 /target/home/kube/save-logs.sh
    - chown 1000:1000 /target/home/kube/save-logs.sh

    # Install boot-log-to-USB script (saves journalctl to CIDATA USB if plugged in)
    - |
      cat > /target/usr/local/bin/save-boot-logs-usb.sh <<'BLOGEOF'
      #!/usr/bin/env bash
      set -euo pipefail
      USB_PART=$(blkid -t LABEL="CIDATA" -o device 2>/dev/null | head -1)
      if [ -z "$USB_PART" ]; then
        echo "No CIDATA USB found, skipping boot log save"
        exit 0
      fi
      MOUNT_DIR="/tmp/usb-bootlogs"
      mkdir -p "$MOUNT_DIR"
      mount "$USB_PART" "$MOUNT_DIR" || exit 1
      LOGDIR="$MOUNT_DIR/boot-logs/$(hostname)/$(date +%Y%m%d-%H%M%S)"
      mkdir -p "$LOGDIR"
      journalctl --boot --no-pager > "$LOGDIR/journalctl-boot.log" 2>&1 || true
      dmesg > "$LOGDIR/dmesg.log" 2>&1 || true
      systemctl --failed --no-pager > "$LOGDIR/failed-services.log" 2>&1 || true
      sync
      umount "$MOUNT_DIR"
      echo "Boot logs saved to $LOGDIR"
      BLOGEOF
    - sed -i 's/^      //' /target/usr/local/bin/save-boot-logs-usb.sh
    - chmod 755 /target/usr/local/bin/save-boot-logs-usb.sh

    # Systemd service to run boot-log save after boot completes
    - |
      cat > /target/etc/systemd/system/save-boot-logs-usb.service <<'SVCEOF'
      [Unit]
      Description=Save boot logs to USB if plugged in
      After=multi-user.target

      [Service]
      Type=oneshot
      ExecStartPre=/bin/sleep 30
      ExecStart=/usr/local/bin/save-boot-logs-usb.sh
      RemainAfterExit=true

      [Install]
      WantedBy=multi-user.target
      SVCEOF

    # Enable all custom services via symlinks (no chroot needed)
    - |
      mkdir -p /target/etc/systemd/system/multi-user.target.wants
      ln -sf /etc/systemd/system/k8s-auto-join.service /target/etc/systemd/system/multi-user.target.wants/k8s-auto-join.service
      ln -sf /etc/systemd/system/save-boot-logs-usb.service /target/etc/systemd/system/multi-user.target.wants/save-boot-logs-usb.service

    # --- Network-dependent section below ---
    # Re-establish WiFi — subiquity drops the DHCP lease during install
    # Then verify DNS works before attempting apt operations
    - |
      IFACE=$(ls /sys/class/net/ | grep -E '^wl' | head -1)
      if [ -n "$IFACE" ]; then
        printf 'network:\n  version: 2\n  wifis:\n    %s:\n      dhcp4: true\n      access-points:\n        "__WIFI_SSID__":\n          password: "__WIFI_PASSWORD__"\n' "$IFACE" > /etc/netplan/99-wifi-early.yaml
        chmod 600 /etc/netplan/99-wifi-early.yaml
        netplan apply 2>/dev/null || true
        echo "Waiting for WiFi IP..." >&2
        for i in $(seq 1 30); do
          if ip addr show "$IFACE" | grep -q 'inet '; then echo "WiFi up" >&2; break; fi
          sleep 2
        done
        ip addr show "$IFACE" >&2
      fi
      echo "Waiting for DNS..." >&2
      for i in $(seq 1 30); do
        if getent hosts archive.ubuntu.com >/dev/null 2>&1; then
          echo "DNS working" >&2
          break
        fi
        sleep 2
      done
      if ! getent hosts archive.ubuntu.com >/dev/null 2>&1; then
        echo "WARNING: DNS not working after 60s, apt commands may fail" >&2
      fi

    # Set up bind mounts so chroot has working DNS + devices
    - |
      mount --bind /dev /target/dev
      mount --bind /proc /target/proc
      mount --bind /run /target/run
      mount --bind /sys /target/sys

    # Install containerd + Kubernetes packages (single block so failures don't break the chain)
    - |
      set +e
      echo "=== Installing containerd ===" >&2
      for attempt in 1 2 3; do
        chroot /target apt-get update -qq 2>&1 && break
        echo "apt-get update attempt $attempt failed, retrying in 10s..." >&2
        sleep 10
      done
      chroot /target apt-get install -y -qq containerd 2>&1
      chroot /target mkdir -p /etc/containerd
      chroot /target bash -c "containerd config default > /etc/containerd/config.toml" 2>&1
      sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /target/etc/containerd/config.toml 2>/dev/null
      chroot /target systemctl enable containerd 2>&1

      echo "=== Adding Kubernetes apt repo ===" >&2
      chroot /target mkdir -p /etc/apt/keyrings
      chroot /target bash -c "curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.35/deb/Release.key | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg" 2>&1
      cat > /target/etc/apt/sources.list.d/kubernetes.list <<REPOEOF
      deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.35/deb/ /
      REPOEOF

      echo "=== Installing kubeadm, kubelet, kubectl ===" >&2
      for attempt in 1 2 3; do
        chroot /target apt-get update -qq 2>&1 && break
        echo "apt-get update attempt $attempt failed, retrying in 10s..." >&2
        sleep 10
      done
      chroot /target apt-get install -y -qq kubelet kubeadm kubectl 2>&1
      chroot /target apt-mark hold kubelet kubeadm kubectl 2>&1
      chroot /target systemctl enable kubelet 2>&1

      # Report result
      if chroot /target which kubeadm >/dev/null 2>&1; then
        echo "=== Kubernetes packages installed successfully ===" >&2
      else
        echo "=== WARNING: Kubernetes packages NOT installed (DNS/network issue during install) ===" >&2
        echo "=== Run node-setup.sh manually after boot to complete setup ===" >&2
      fi
      true

    # Clean up bind mounts
    - |
      umount /target/sys 2>/dev/null || true
      umount /target/run 2>/dev/null || true
      umount /target/proc 2>/dev/null || true
      umount /target/dev 2>/dev/null || true

    # Rook Ceph: if disk has >100G in the VG, shrink root LV to 100G
    # and create a raw LV (no filesystem) for Ceph OSD storage.
    # Disks with <=100G are left as-is — they won't be Ceph nodes.
    - |
      set +e
      VG_NAME="ubuntu-vg"
      LV_PATH="/dev/${VG_NAME}/ubuntu-lv"
      MIN_ROOT_G=100
      vgs "$VG_NAME" >/dev/null 2>&1 || { echo "VG $VG_NAME not found, skipping Ceph LV" >&2; exit 0; }
      VG_SIZE_B=$(vgs --noheadings --nosuffix --units b -o vg_size "$VG_NAME" 2>/dev/null | tr -d ' ')
      VG_SIZE_G=$((VG_SIZE_B / 1073741824))
      if [ "$VG_SIZE_G" -le "$MIN_ROOT_G" ]; then
        echo "=== Rook Ceph: VG is ${VG_SIZE_G}G (<= ${MIN_ROOT_G}G) — not a Ceph node ===" >&2
        exit 0
      fi
      echo "=== Rook Ceph: VG is ${VG_SIZE_G}G — creating Ceph OSD LV ===" >&2
      # Save mount state under /target so we can restore it afterward
      MOUNT_SAVE=$(mktemp)
      findmnt -rn -o TARGET,SOURCE | awk '$1 ~ "^/target"' | sort -r > "$MOUNT_SAVE"
      # Unmount /target tree (deepest mounts first)
      while read -r tgt src; do
        [ -n "$tgt" ] && { umount "$tgt" 2>/dev/null || umount -l "$tgt" 2>/dev/null || true; }
      done < "$MOUNT_SAVE"
      # Shrink filesystem to 99G first (1G safety buffer), then shrink LV to 100G,
      # then expand filesystem to fill the exact LV size
      if e2fsck -f -y "$LV_PATH" >&2 && resize2fs "$LV_PATH" 99G >&2; then
        lvreduce -f -L ${MIN_ROOT_G}G "$LV_PATH" >&2
        resize2fs "$LV_PATH" >&2
        # Create raw LV for Rook Ceph (no filesystem — Ceph manages the block device)
        lvcreate -l 100%FREE -n ceph-osd "$VG_NAME" >&2
        echo "=== Rook Ceph: OSD LV created ===" >&2
        lvs "$VG_NAME" >&2
      else
        echo "=== Rook Ceph: filesystem resize failed, skipping ===" >&2
      fi
      # Remount everything (shallowest first)
      sort "$MOUNT_SAVE" | while read -r tgt src; do
        [ -n "$tgt" ] && { mount "$src" "$tgt" 2>/dev/null || true; }
      done
      rm -f "$MOUNT_SAVE"
      true

    # Copy install logs to USB drive for debugging
    - |
      USB_PART=$(blkid -t LABEL="CIDATA" -o device 2>/dev/null | head -1)
      if [ -n "$USB_PART" ]; then
        mkdir -p /tmp/usblogs
        mount "$USB_PART" /tmp/usblogs 2>/dev/null || true
        if mountpoint -q /tmp/usblogs; then
          LOGDIR="/tmp/usblogs/install-logs/$(date +%Y%m%d-%H%M%S)"
          mkdir -p "$LOGDIR"
          cp /var/log/installer/*.log "$LOGDIR/" 2>/dev/null || true
          cp /autoinstall.yaml "$LOGDIR/" 2>/dev/null || true
          sync
          umount /tmp/usblogs
        fi
      fi
