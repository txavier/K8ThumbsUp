# Copy to secrets.env and fill in real values.
# secrets.env is gitignored — it stays on your machine only.

WIFI_SSID="your-ssid"
WIFI_PASSWORD="your-password"

MASTER_IP=""
MASTER_USER=""

# Generate with: mkpasswd --method=SHA-512 yourpassword
# If omitted, prepare-usb.sh will prompt for a plaintext password and hash it.
# IMPORTANT: use single quotes — the hash contains $ characters that bash would expand.
PASSWORD_HASH=''
