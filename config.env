# config.env — Build-time configuration for prepare-usb.sh / prepare-head-usb.sh
# This file is tracked in git (no secrets here).

# Reserve free VG space for Rook/Ceph OSD?
#   true  → root LV is fixed at ROOT_LV_SIZE (default 45G), rest of VG is free for Ceph
#   false → root LV fills the entire VG (no space reserved)
RESERVE_CEPH_STORAGE=false

# Size of the root logical volume when RESERVE_CEPH_STORAGE=true.
# Ignored when RESERVE_CEPH_STORAGE=false.
ROOT_LV_SIZE="45G"

# Packages to pre-download onto the USB for offline installation.
# Space-separated. Each package and all its dependencies are fetched at USB-prep
# time and embedded in the ISO under drivers/.  During autoinstall subiquity uses
# them via a local apt file:// source so the install succeeds even when the node
# has no working network adapter yet.
# Requires dpkg-dev on the build machine (sudo apt install dpkg-dev).
OFFLINE_PACKAGES="linux-firmware iw wireless-tools wpasupplicant linux-headers-generic rtl8812au-dkms"
