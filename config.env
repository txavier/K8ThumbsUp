# config.env — Build-time configuration for prepare-usb.sh / prepare-head-usb.sh
# This file is tracked in git (no secrets here).

# Reserve free VG space for Rook/Ceph OSD?
#   true  → root LV is fixed at ROOT_LV_SIZE (default 45G), rest of VG is free for Ceph
#   false → root LV fills the entire VG (no space reserved)
RESERVE_CEPH_STORAGE=false

# Size of the root logical volume when RESERVE_CEPH_STORAGE=true.
# Ignored when RESERVE_CEPH_STORAGE=false.
ROOT_LV_SIZE="45G"

# Packages to pre-download onto the USB for offline installation.
# Space-separated. Each package and all its dependencies are fetched at USB-prep
# time and embedded in the ISO under drivers/.  During autoinstall subiquity uses
# them via a local apt file:// source so the install succeeds even when the node
# has no working network adapter yet.
# Requires dpkg-dev on the build machine (sudo apt install dpkg-dev).
# Kernel version pinning:
# Do NOT list `linux-image-*` / `linux-headers-*-generic` / `linux-headers-generic`
# here.  The kernel version that the live ISO's minimal squashfs preinstalls is
# fixed by the ISO (e.g. ubuntu-24.04.4 → 6.8.0-100).  prepare-usb.sh detects
# that version from `casper/filesystem.manifest` at build time and auto-appends
# the matching `linux-headers-<abi>-generic` and `linux-modules-extra-<abi>-generic`
# packages to this list.  This guarantees the offline cache matches whatever
# subiquity already installed from cdrom: and avoids version-skew failures
# (linux-headers-generic metapackage pulling in a different ABI than what's
# actually on disk, causing apt to try to upgrade to a kernel we don't have).
#
# WiFi adapter coverage on the USB (no-network install support):
#   * linux-firmware                  — firmware blobs for nearly every modern
#                                       PCIe WiFi chipset (Intel, Atheros,
#                                       Broadcom, MediaTek, Realtek PCIe, ...)
#   * linux-modules-extra-<abi>-generic — in-tree out-of-mainline modules
#                                       (rtw88, rtw89, mt76, mwifiex, ...) —
#                                       AUTO-APPENDED by prepare-usb.sh
#   * linux-headers-<abi>-generic     — needed for DKMS to compile against the
#                                       running kernel — AUTO-APPENDED
#   * iw / wireless-tools / wpasupplicant — userspace WiFi stack
#   * rtl8812au-dkms                  — Realtek RTL88XXAU USB (AC600/AC1200)
#   * backport-iwlwifi-dkms           — newer/backported Intel iwlwifi
#   * broadcom-sta-dkms               — Broadcom STA (wl) driver, older BCM43xx
#   * build-essential / dkms          — DKMS build toolchain
OFFLINE_PACKAGES="linux-firmware iw wireless-tools wpasupplicant dkms build-essential rtl8812au-dkms backport-iwlwifi-dkms broadcom-sta-dkms"

# Build the out-of-tree RTL8852CU DKMS driver from morrownr/rtl8852cu-20251113 on
# GitHub and bundle the resulting .deb in drivers/.  This covers USB
# WiFi 6 (802.11ax) adapters with Realtek 8852CU chips (e.g. idVendor
# 0db0 idProduct 991d) — there is no Ubuntu apt package for the USB
# variant, and the in-kernel rtw89 driver only handles the PCIe ones.
#
# Requires `git`, `dkms`, `build-essential`, and `dpkg-dev` on the build
# host plus internet access to clone the repo (cached under
# ~/.cache/k8thumbsup/rtl8852cu-src on subsequent runs).
#
# Set to 0 to skip (e.g. on hosts without these tools, or for faster
# builds when you know no 8852cu adapters will be used).  The install
# still succeeds; only that specific chip stays unsupported.
BUILD_RTL8852CU=1
